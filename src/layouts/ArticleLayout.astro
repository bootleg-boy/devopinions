---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  kind: 'blog' | 'note' | 'project';
  backHref: string;
  backLabel: string;
  noindex?: boolean;
  // Reading time estimate (optional)
  readingTime?: number;
}

const {
  title,
  description,
  date,
  updated,
  tags = [],
  image,
  imageAlt,
  kind,
  backHref,
  backLabel,
  noindex = false,
  readingTime,
} = Astro.props;

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);

const updatedFmt = updated
  ? new Intl.DateTimeFormat('en-GB', { year: 'numeric', month: 'long', day: 'numeric' }).format(updated)
  : null;

const kindLabel = { blog: 'Article', note: 'Note', project: 'Case Study' }[kind];
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  type="article"
  publishDate={date}
  modifiedDate={updated}
  tags={tags}
  noindex={noindex}
>
  <article class="article">
    <header class="article-header">
      <div class="article-meta">
        <span>{kindLabel}</span>
        <span class="dot">·</span>
        <time datetime={date.toISOString()}>{dateFmt}</time>
        {updatedFmt && (
          <>
            <span class="dot">·</span>
            <span>Updated {updatedFmt}</span>
          </>
        )}
        {readingTime && (
          <>
            <span class="dot">·</span>
            <span>{readingTime} min read</span>
          </>
        )}
      </div>
      <h1 class="article-title">{title}</h1>
      <p class="article-desc">{description}</p>
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer class="article-footer">
      <a href={backHref} class="back-link">← {backLabel}</a>
      {tags.length > 0 && (
        <div class="entry-tags">
          {tags.map((t) => <span class="entry-tag">{t}</span>)}
        </div>
      )}
    </footer>
  </article>
</BaseLayout>
