---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get all blog posts, exclude drafts, sort newest first
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-GB', { year: 'numeric', month: 'short', day: '2-digit' }).format(d);
---

<BaseLayout
  title="Blog"
  description="Long-form writing on full-stack engineering, Azure architecture, Angular, ASP.NET, and the trade-offs of shipping production systems."
>
  <div class="list-page">
    <div class="list-header">
      <div class="s-eyebrow">Writing</div>
      <h1 class="s-title">Articles &amp; <em>opinions</em></h1>
      <p class="list-intro">
        Long-form posts on the trade-offs I've actually made — production architecture, performance
        recoveries, the bugs that taught me something. Written for engineers facing the same calls.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="list-intro">No posts yet — first one's on the way.</p>
    ) : (
      <div class="entry-list">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} style="display: contents;">
            <article class="entry">
              <time class="entry-date" datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
              <div>
                <h2 class="entry-title"><span>{post.data.title}</span></h2>
                <p class="entry-desc">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="entry-tags">
                    {post.data.tags.map((t) => <span class="entry-tag">{t}</span>)}
                  </div>
                )}
              </div>
              <span class="entry-arrow">→</span>
            </article>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
